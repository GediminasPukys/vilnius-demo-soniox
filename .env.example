# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Soniox (STT)
SONIOX_API_KEY=

# Human handoff (warm SIP transfer to Klientų aptarnavimo skyrius operator)
LIVEKIT_SIP_OUTBOUND_TRUNK=
LIVEKIT_OPERATOR_PHONE_NUMBER=+37052112000
LIVEKIT_SIP_NUMBER=

# LLM uses LiveKit Inference (model descriptor in agent.py:
# ``openai/gpt-5.3-chat-latest``) — no separate provider API key needed.

# Google Cloud service-account JSON — used by the TTS (Gemini 3.1 Flash).
# Inline the full JSON here on a single line (no formatting), e.g.:
#   GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
# Alternative: set GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json instead.
GOOGLE_CREDENTIALS=

# Optional toggles
LOG_LEVEL=INFO

# session.started webhook — fires once per call to your backend.
# Leave unset to disable. Auth is HTTP Basic with the user/password
# below (intentionally primitive for the demo).
VILNIUS_WEBHOOK_URL=
VILNIUS_WEBHOOK_USER=NFQ
VILNIUS_WEBHOOK_PASSWORD=NFQscaling
